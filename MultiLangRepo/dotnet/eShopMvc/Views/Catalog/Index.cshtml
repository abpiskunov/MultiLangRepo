@model IEnumerable<eShopMvc.Models.CatalogItem>

@{
    ViewBag.Title = "Catalog";
}

<h2>Catalog</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

<div class="row">
    <div class="col-md-12">
        @using (Html.BeginForm("Index", "Catalog", FormMethod.Get))
        {
            <div class="form-inline">
                <div class="form-group">
                    @Html.Label("Brand:")
                    @Html.DropDownList("brandFilter", (SelectList)ViewBag.Brands, "All", new { @class = "form-control" })
                </div>
                <div class="form-group">
                    @Html.Label("Type:")
                    @Html.DropDownList("typeFilter", (SelectList)ViewBag.Types, "All", new { @class = "form-control" })
                </div>
                <button type="submit" class="btn btn-primary">Filter</button>
            </div>
        }
    </div>
</div>

<div class="row" style="margin-top: 20px;">
    @foreach (var item in Model)
    {
        <div class="col-md-4" style="margin-bottom: 20px;">
            <div class="panel panel-default">
                <div class="panel-body">
                    <h4>@item.Name</h4>
                    <p>@item.Description</p>
                    <p class="text-primary"><strong>$@item.Price.ToString("F2")</strong></p>
                    <p><small>@item.CatalogBrand.Brand | @item.CatalogType.Type</small></p>
                    @using (Html.BeginForm("AddToCart", "Catalog", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.Hidden("id", item.Id)
                        <button type="submit" class="btn btn-success btn-sm">Add to Cart</button>
                    }
                </div>
            </div>
        </div>
    }
</div>
